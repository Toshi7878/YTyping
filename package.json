{
  "name": "ytyping",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.15.1",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "check": "biome check --diagnostic-level=warn --reporter=summary",
    "check:fix": "biome check --diagnostic-level=warn --reporter=summary --write",
    "typecheck": "next typegen && tsgo",
    "reset": "pnpm dlx rimraf .next .tsbuildinfo node_modules package-lock.json && pnpm install",
    "db:start": "pnpx supabase start",
    "db:stop": "pnpx supabase stop",
    "db:push": "drizzle-kit push",
    "studio": "drizzle-kit studio",
    "db:generate": "drizzle-kit generate",
    "db:reset": "pnpx supabase db reset",
    "db:status": "pnpx supabase status",
    "db:seed": "pnpx tsx --env-file=.env src/server/drizzle/seed/index.ts",
    "db:seed:bucket-policy": "pnpx tsx --env-file=.env src/server/drizzle/seed/bucket-policy.ts",
    "pp:recalculate": "dotenv -e .env -- pnpx tsx src/server/drizzle/scripts/recalculate-all-pp.ts",
    "tags:normalize": "dotenv -e .env -- pnpx tsx src/server/drizzle/scripts/normalize-map-tags.ts",
    "prepare": "husky",
    "types:build": "tsx node_modules/dts-bundle-generator/dist/bin/dts-bundle-generator.js --config dts-bundle-generator.config.ts"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.9",
    "@aws-sdk/client-s3": "^3.896.0",
    "@bprogress/next": "^3.2.12",
    "@pixi/sound": "^6.0.1",
    "@pixi/ticker": "^7.4.3",
    "@supabase/supabase-js": "^2.58.0",
    "@t3-oss/env-nextjs": "^0.13.8",
    "@tailwindcss/postcss": "^4.1.13",
    "@tanstack/react-form": "^1.33.2",
    "@tanstack/react-query": "^5.100.9",
    "@tanstack/react-table": "^8.21.3",
    "@trpc/client": "^11.17.0",
    "@trpc/server": "^11.17.0",
    "@trpc/tanstack-react-query": "^11.17.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "@vercel/analytics": "^1.6.1",
    "@vercel/sdk": "^1.18.7",
    "ai": "^6.0.37",
    "autoprefixer": "^10.4.21",
    "better-auth": "^1.4.20",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dexie": "^4.2.0",
    "dexie-react-hooks": "^4.2.0",
    "drizzle-orm": "1.0.0-rc.4-de6c356",
    "fast-deep-equal": "^3.1.3",
    "googleapis": "^171.0.0",
    "html-react-parser": "^5.2.6",
    "jotai": "^2.20.0",
    "jotai-optics": "^0.4.0",
    "jotai-uncontrolled": "^0.4.1",
    "lucide-react": "^0.577.0",
    "lyrics-ime-typing-engine": "^1.2.14",
    "lyrics-typing-engine": "^2.1.0",
    "motion": "^12.38.0",
    "nanoid": "^5.1.6",
    "next": "16.2.10",
    "next-themes": "^0.4.6",
    "nuqs": "^2.7.0",
    "postcss": "^8.5.6",
    "postgres": "^3.4.9",
    "radix-ui": "^1.4.3",
    "react": "19.2.8",
    "react-activity-calendar": "^3.0.1",
    "react-dom": "19.2.7",
    "react-hotkeys-hook": "^5.3.2",
    "react-icons": "^5.5.0",
    "react-intersection-observer": "^10.0.0",
    "react-youtube": "^10.1.0",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "superjson": "^2.2.2",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.13",
    "tailwindcss-animate": "^1.0.7",
    "trpc-to-openapi": "^3.2.0",
    "ua-parser-js": "^2.0.5",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.20",
    "@biomejs/biome": "2.5.4",
    "@types/node": "^24.5.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/youtube": "^0.3.0",
    "@typescript/native-preview": "7.0.0-dev.20260707.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "csv-parse": "^6.1.0",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "1.0.0-rc.4-ca0f029",
    "dts-bundle-generator": "^9.0.0",
    "husky": "^9.1.7",
    "supabase": "^2.48.3",
    "tsx": "^4.22.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^7.0.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Toshi7878/YTyping",
    "directory": "ytyping"
  }
}
